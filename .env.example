# OpenAI
# Install the SDK with: python3 -m pip install openai
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5.4-mini

# SMTP
# Common examples:
# - 163: smtp.163.com / 465 / SSL
# - QQ: smtp.qq.com / 465 / SSL
# - Gmail: smtp.gmail.com / 465 / SSL, use an app password
SMTP_HOST=
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_STARTTLS=false
SMTP_USERNAME=
SMTP_PASSWORD=
SENDER_EMAIL=
SENDER_NAME=

# Resume and profile
RESUME_PATH=
PROFILE_PATH=config/profile.json
